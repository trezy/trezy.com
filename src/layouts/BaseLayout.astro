---
import { SITE_NAME, TWITTER } from '@lib/site.js'
import SiteFooter from '@components/SiteFooter.astro'
import SiteNav from '@components/SiteNav.astro'
import '../styles/reset.css'
const { title, description = '', image = null, imageAlt = null, showFooter = true, class: className = '' } = Astro.props
const fullTitle = title === 'Home' ? SITE_NAME : `${title} | ${SITE_NAME}`
const resolvedImage = image ? new URL(image, Astro.site).href : null
const GA_ID = import.meta.env.PUBLIC_GA_ID
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="theme-color" content="#0092c7" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" />
    <link rel="webmention" href="https://webmention.io/trezy.com/webmention" />
    <link rel="pingback" href="https://webmention.io/trezy.com/xmlrpc" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {resolvedImage && <meta property="og:image" content={resolvedImage} />}
    {image && imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:site" content={TWITTER} />
    <meta name="twitter:creator" content={TWITTER} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {resolvedImage && <meta name="twitter:image" content={resolvedImage} />}
    <slot name="head" />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme')
          var theme = stored || 'system'
          var effective = theme

          if (theme === 'system') {
            effective = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
          }

          document.documentElement.dataset.theme = effective
        } catch (err) {
          // localStorage/matchMedia may be unavailable (e.g. privacy mode); fall back silently
        }
      })()
    </script>
    {GA_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${GA_ID}')`}></script>
      </>
    )}
  </head>
  <body>
    <div id="application-wrapper">
      <slot name="banner"><SiteNav /></slot>
      <main class:list={['page', className]}>
        <slot />
      </main>
      {showFooter && <slot name="footer"><SiteFooter /></slot>}
    </div>
  </body>
</html>
